rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roleIs(role) {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function roleIn(roles) {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isSuperadmin() {
      return roleIs('superadmin');
    }

    function isAdminLike() {
      return roleIn(['superadmin', 'admin']);
    }

    function isPilot() {
      return roleIs('pilot');
    }

match /activity_logs/{docId} {
  allow read: if true;  // publik, untuk verifikasi QR
  allow create: if isAdminLike()
    || (isPilot() && request.resource.data.pilot_uid == request.auth.uid);
  allow update: if isAdminLike()
    || (isPilot() && (
      resource.data.get('pilot_uid', null) == request.auth.uid
      || request.resource.data.get('pilot_uid', null) == request.auth.uid
      || resource.data.get('pilot_uid', null) == null
    ));
  allow delete: if isAdminLike();
}

match /users/{userId} {
  allow read: if true;  // publik, untuk verifikasi QR (nama & tanda tangan)
  allow create: if isSuperadmin();
  allow update: if isSuperadmin()
    || (
      signedIn()
      && request.auth.uid == userId
      && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'email', 'updated_at', 'search_tokens'])
    );
  allow delete: if isSuperadmin();
}

match /settings/{docId} {
  allow read: if true;  // publik untuk verifikasi QR
  allow write: if isSuperadmin();
}

    match /counters/{docId} {
      allow read, write: if isAdminLike() || isPilot();
    }

    match /pilotage_logs/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminLike();
    }

    match /assistance_logs/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminLike();
    }

    match /assist_tugs/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdminLike();
    }

    match /password_resets/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
